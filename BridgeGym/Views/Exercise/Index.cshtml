@{
    ViewData["Title"] = "Bridge Gym - Setup";
}

<div class="text-center">
    <h1 class="display-4">Welcome to Bridge Gym</h1>
    <p>Practice counting Honour Card Points (HCP) quickly.</p>
    
    <div class="card mt-5 mx-auto" style="max-width: 500px;">
        <div class="card-body">
            <h5 class="card-title">Start a new session</h5>
            <form asp-action="StartSession" method="post" class="text-start">
                <div class="mb-3">
                    <label class="form-label fw-bold">Exercise Mode:</label>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="mode" id="modeDefence" value="Defence" checked>
                        <label class="form-check-label" for="modeDefence">
                            <strong>Defence Mode</strong><br/>
                            <small class="text-muted">Count missing HCP when you see South & Dummy.</small>
                        </label>
                    </div>
                    <div class="form-check mt-2">
                        <input class="form-check-input" type="radio" name="mode" id="modeSimple" value="Simple">
                        <label class="form-check-label" for="modeSimple">
                            <strong>Simple Mode</strong><br/>
                            <small class="text-muted">Count HCP for just your own hand (South).</small>
                        </label>
                    </div>
                </div>

                <div class="mb-4">
                    <label for="numHands" class="form-label fw-bold">Number of hands to practice:</label>
                    <select name="numHands" id="numHands" class="form-select">
                        <option value="10">10 hands</option>
                        <option value="20">20 hands</option>
                        <option value="30">30 hands</option>
                    </select>
                </div>
                <button type="submit" class="btn btn-primary w-100 btn-lg">Start Session</button>
            </form>
        </div>
    </div>
</div>
