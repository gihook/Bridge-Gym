@model HandExerciseViewModel
@{
    ViewData["Title"] = "Bridge Gym - Playing";

    var suits = new[] {
        BridgeGym.Models.Bridge.Suit.Spades,
        BridgeGym.Models.Bridge.Suit.Hearts,
        BridgeGym.Models.Bridge.Suit.Diamonds,
        BridgeGym.Models.Bridge.Suit.Clubs
    };
    
    // Classic 4-color BBO styling
    var suitColors = new Dictionary<BridgeGym.Models.Bridge.Suit, string> {
        { BridgeGym.Models.Bridge.Suit.Spades, "black" },
        { BridgeGym.Models.Bridge.Suit.Hearts, "#d32f2f" },
        { BridgeGym.Models.Bridge.Suit.Diamonds, "#e65c00" }, // Orange
        { BridgeGym.Models.Bridge.Suit.Clubs, "#2e7d32" } // Green
    };
}

<style>
    .bridge-table {
        background-color: #35654d; /* Classic green felt */
        border-radius: 15px;
        padding: 20px 10px;
        margin-top: 20px;
        box-shadow: inset 0 0 30px rgba(0,0,0,0.6);
        min-height: 400px;
        position: relative;
    }

    .bbo-hand {
        display: inline-block;
        background-color: #ffffe0; /* Light yellow background */
        border: 2px solid #333;
        border-radius: 6px;
        width: 100%;
        max-width: 180px;
        text-align: left;
        box-shadow: 4px 4px 10px rgba(0,0,0,0.4);
        margin: 5px auto;
    }

    .hand-header {
        background-color: #e0e0e0;
        padding: 3px 5px;
        font-weight: bold;
        border-bottom: 2px solid #333;
        text-align: center;
        font-size: 0.9rem;
        color: #333;
    }

    .hand-body {
        padding: 5px 10px;
        font-family: Arial, Helvetica, sans-serif;
        font-size: 1.3rem;
        font-weight: bold;
        line-height: 1.3;
    }

    /* Larger fonts for bigger screens */
    @@media (min-width: 768px) {
        .bridge-table { padding: 40px 20px; min-height: 500px; }
        .hand-header { font-size: 1.1rem; padding: 5px 10px; }
        .hand-body { font-size: 1.6rem; line-height: 1.5; padding: 10px 15px; }
        .bbo-hand { max-width: 220px; }
    }

    .suit-icon {
        display: inline-block;
        width: 25px;
        text-align: center;
    }

    .cards {
        letter-spacing: 1px;
    }

    .timer-badge {
        font-size: 1.2rem;
        font-family: monospace;
        background: #222;
        color: #0f0;
        padding: 5px 10px;
        border-radius: 5px;
        border: 2px solid #555;
    }

    @@media (min-width: 768px) {
        .timer-badge { font-size: 1.5rem; padding: 5px 15px; }
        .cards { letter-spacing: 2px; }
    }

    .input-area {
        background: rgba(255, 255, 255, 0.95);
        border: 2px solid #333;
        border-radius: 10px;
        padding: 15px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.5);
        max-width: 250px;
        margin: 0 auto;
    }

    @@media (max-width: 767px) {
        .dummy-col { order: 1; }
        .input-col { order: 3; margin-top: 20px; }
        .south-col { order: 2; margin-top: 20px; }
        
        .bridge-table {
            display: flex;
            flex-direction: column;
            align-items: center;
        }
        
        .table-row-top {
            display: contents;
        }
    }
</style>

<div class="container-fluid px-2 px-md-4">
    <div class="d-flex justify-content-between align-items-center mt-3">
        <h2 class="h4 h2-md">Hand @Model.CurrentHandNumber/@Model.TotalHandsInSession</h2>
        <div id="timer" class="timer-badge">0.0s</div>
    </div>

    <div class="bridge-table">
        <div class="row w-100 m-0 table-row-top">
            <!-- West/East Dummy Logic -->
            <div class="col-md-4 dummy-col text-center text-md-end mb-3 mb-md-0">
                @if (Model.DummyPosition == "West")
                {
                    <div class="bbo-hand">
                        <div class="hand-header">Dummy (West)</div>
                        <div class="hand-body">
                            @foreach (var suit in suits)
                            {
                                var cardsInSuit = Model.DummyHand.Where(c => c.Suit == suit).OrderByDescending(c => c.Rank);
                                <div class="suit-line">
                                    <span class="suit-icon" style="color: @suitColors[suit]">@GetSuitSymbol(suit)</span>
                                    <span class="cards">@(cardsInSuit.Any() ? string.Join("", cardsInSuit.Select(c => GetRankChar(c.Rank))) : "—")</span>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>

            <!-- Center Input Area -->
            <div class="col-md-4 input-col d-flex justify-content-center align-items-center">
                <div class="input-area text-center">
                    <h6 class="mb-2">Remaining HCP?</h6>
                    <div class="input-group mb-2">
                        <input type="number" id="hcpInput" class="form-control form-control-lg text-center" style="font-weight: bold;" autofocus>
                    </div>
                    <button class="btn btn-primary w-100" type="button" id="submitBtn">Submit</button>
                    <div id="feedback" class="mt-2 fw-bold" style="height: 20px; font-size: 1rem;"></div>
                </div>
            </div>

            <!-- East Dummy -->
            <div class="col-md-4 dummy-col text-center text-md-start mb-3 mb-md-0">
                @if (Model.DummyPosition == "East")
                {
                    <div class="bbo-hand">
                        <div class="hand-header">Dummy (East)</div>
                        <div class="hand-body">
                            @foreach (var suit in suits)
                            {
                                var cardsInSuit = Model.DummyHand.Where(c => c.Suit == suit).OrderByDescending(c => c.Rank);
                                <div class="suit-line">
                                    <span class="suit-icon" style="color: @suitColors[suit]">@GetSuitSymbol(suit)</span>
                                    <span class="cards">@(cardsInSuit.Any() ? string.Join("", cardsInSuit.Select(c => GetRankChar(c.Rank))) : "—")</span>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="row w-100 m-0 south-col">
            <div class="col-12 text-center mt-3 mt-md-5">
                <div class="bbo-hand">
                    <div class="hand-header">You (South)</div>
                    <div class="hand-body">
                        @foreach (var suit in suits)
                        {
                            var cardsInSuit = Model.SouthHand.Where(c => c.Suit == suit).OrderByDescending(c => c.Rank);
                            <div class="suit-line">
                                <span class="suit-icon" style="color: @suitColors[suit]">@GetSuitSymbol(suit)</span>
                                <span class="cards">@(cardsInSuit.Any() ? string.Join("", cardsInSuit.Select(c => GetRankChar(c.Rank))) : "—")</span>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<form id="nextHandForm" asp-action="Play" method="get" style="display: none;">
    <input type="hidden" name="handIndex" value="@(Model.CurrentHandNumber + 1)">
    <input type="hidden" name="totalHands" value="@Model.TotalHandsInSession">
    <input type="hidden" name="totalTime" id="totalTimeInput">
    <input type="hidden" name="handTimes" id="handTimesInput" value="@ViewBag.HandTimes">
</form>

@functions {
    string GetSuitSymbol(BridgeGym.Models.Bridge.Suit suit) => suit switch
    {
        BridgeGym.Models.Bridge.Suit.Spades => "♠",
        BridgeGym.Models.Bridge.Suit.Hearts => "♥",
        BridgeGym.Models.Bridge.Suit.Diamonds => "♦",
        BridgeGym.Models.Bridge.Suit.Clubs => "♣",
        _ => ""
    };

    string GetRankChar(BridgeGym.Models.Bridge.Rank rank) => rank switch
    {
        BridgeGym.Models.Bridge.Rank.Ace => "A",
        BridgeGym.Models.Bridge.Rank.King => "K",
        BridgeGym.Models.Bridge.Rank.Queen => "Q",
        BridgeGym.Models.Bridge.Rank.Jack => "J",
        BridgeGym.Models.Bridge.Rank.Ten => "T", // Standard BBO syntax for 10
        _ => ((int)rank).ToString()
    };
}

@section Scripts {
    <script>
        let startTime = Date.now();
        let currentSessionTotalTime = @Model.CurrentSessionTotalTime;
        let expectedHcp = @Model.ExpectedHcp;
        
        let timerInterval = setInterval(() => {
            let elapsed = (Date.now() - startTime) / 1000;
            document.getElementById('timer').innerText = elapsed.toFixed(1) + 's';
        }, 100);

        function submitAnswer() {
            let answer = parseInt(document.getElementById('hcpInput').value);
            let feedback = document.getElementById('feedback');
            
            if (answer === expectedHcp) {
                clearInterval(timerInterval);
                let handTime = (Date.now() - startTime) / 1000;
                let newTotalTime = currentSessionTotalTime + handTime;
                
                feedback.innerText = "Correct!";
                feedback.className = "mt-2 text-success fw-bold";
                
                document.getElementById('totalTimeInput').value = newTotalTime;
                let currentHandTimes = document.getElementById('handTimesInput').value;
                document.getElementById('handTimesInput').value = currentHandTimes ? currentHandTimes + "," + handTime : handTime;
                
                setTimeout(() => {
                    document.getElementById('nextHandForm').submit();
                }, 500);
            } else {
                feedback.innerText = "Incorrect, try again.";
                feedback.className = "mt-2 text-danger fw-bold";
                document.getElementById('hcpInput').value = '';
                document.getElementById('hcpInput').focus();
            }
        }

        document.getElementById('submitBtn').addEventListener('click', submitAnswer);
        document.getElementById('hcpInput').addEventListener('keypress', function (e) {
            if (e.key === 'Enter') {
                submitAnswer();
            }
        });
    </script>
}
