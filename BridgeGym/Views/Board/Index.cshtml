@model IEnumerable<BridgeGym.Models.Bridge.Board>
@{
    ViewData["Title"] = "Boards";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center">
        <h2>Saved Boards</h2>
        <a asp-action="Upload" class="btn btn-success">Upload New Hand</a>
    </div>
    <hr />

    <div class="row">
        @foreach (var board in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">Board #@board.BoardNumber</h5>
                        <p class="card-text">
                            <strong>Hands Filled:</strong> @board.Hands.Count / 4
                            <br />
                            <small class="text-muted">
                                Seats: @(string.Join(", ", board.Hands.Select(h => h.Seat.ToString())))
                            </small>
                        </p>
                        <div class="progress mb-3" style="height: 10px;">
                            <div class="progress-bar @(board.Hands.Count == 4 ? "bg-success" : "bg-warning")" 
                                 role="progressbar" 
                                 style="width: @(board.Hands.Count * 25)%" 
                                 aria-valuenow="@board.Hands.Count" 
                                 aria-valuemin="0" 
                                 aria-valuemax="4"></div>
                        </div>
                        <a asp-action="Details" asp-route-id="@board.Id" class="btn btn-outline-primary">View Details</a>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info mt-3">
            No boards have been uploaded yet. <a asp-action="Upload">Upload your first hand!</a>
        </div>
    }
</div>
