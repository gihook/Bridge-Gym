@{
    ViewData["Title"] = "Upload Board Diagrams";
}

<div class="container mt-4">
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="BoardSet" asp-action="Index">Board Sets</a></li>
        <li class="breadcrumb-item"><a asp-controller="BoardSet" asp-action="Details" asp-route-id="@ViewBag.BoardSetId">Set Details</a></li>
        <li class="breadcrumb-item active" aria-current="page">Upload Diagrams</li>
      </ol>
    </nav>

    <h2>Upload Board Diagrams</h2>
    <p class="text-muted">Upload one or more images of full board diagrams (showing all 4 hands and board number). Each image will be processed to create or update a board.</p>
    <hr />

    <form asp-action="UploadDiagram" method="post" enctype="multipart/form-data">
        <input type="hidden" name="boardSetId" value="@ViewBag.BoardSetId" />
        
        <div class="mb-4">
            <label for="images" class="form-label">Diagram Images</label>
            <input type="file" name="images" id="images" class="form-control" accept="image/*" multiple required />
            <div class="form-text">You can select multiple images at once.</div>
        </div>

        <div asp-validation-summary="All" class="text-danger"></div>

        <div class="mb-3">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-upload"></i> Upload and Process
            </button>
            <a asp-controller="BoardSet" asp-action="Details" asp-route-id="@ViewBag.BoardSetId" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>
