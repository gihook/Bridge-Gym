@model BridgeGym.Models.Bridge.BoardSet
@{
    ViewData["Title"] = $"Board Set: {Model.Name}";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h2>Board Set: @Model.Name</h2>
            <p class="text-muted">Created on @Model.CreatedAt.ToLocalTime().ToString("g")</p>
        </div>
        <div>
            <a asp-action="Export" asp-route-id="@Model.Id" class="btn btn-outline-success">Export PBN</a>
            <a asp-controller="Board" asp-action="UploadDiagram" asp-route-boardSetId="@Model.Id" class="btn btn-primary">Upload Diagrams</a>
            <a asp-controller="Board" asp-action="Upload" asp-route-boardSetId="@Model.Id" class="btn btn-success">Upload New Hand</a>
            <a asp-action="Index" class="btn btn-secondary">Back to List</a>
        </div>
    </div>
    <hr />

    <div class="row">
        @foreach (var board in Model.Boards.OrderBy(b => b.BoardNumber))
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">Board #@board.BoardNumber</h5>
                        <div class="mt-3 d-flex justify-content-between">
                            <a asp-controller="Board" asp-action="Details" asp-route-id="@board.Id" class="btn btn-outline-primary">View Details</a>
                            <form asp-controller="Board" asp-action="Delete" asp-route-id="@board.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this entire board?');">
                                <button type="submit" class="btn btn-outline-danger btn-sm">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (!Model.Boards.Any())
    {
        <div class="alert alert-info mt-3">
            No boards have been uploaded to this set yet. <a asp-controller="Board" asp-action="Upload" asp-route-boardSetId="@Model.Id">Upload your first hand!</a>
        </div>
    }
</div>
