@model IEnumerable<BridgeGym.Models.Bridge.BoardSet>
@{
    ViewData["Title"] = "Board Sets";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center">
        <h2>Board Sets</h2>
        <a asp-action="Create" class="btn btn-primary">Create New Set</a>
    </div>
    <hr />

    <div class="row">
        @foreach (var set in Model)
        {
            <div class="col-md-6 mb-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <h5 class="card-title">@set.Name</h5>
                                <p class="card-text text-muted">
                                    Created on @set.CreatedAt.ToLocalTime().ToString("g")
                                </p>
                            </div>
                            <span class="badge bg-secondary">@set.Boards.Count Boards</span>
                        </div>
                        <div class="mt-3">
                            <a asp-action="Details" asp-route-id="@set.Id" class="btn btn-outline-primary">View Boards</a>
                            <a asp-action="Export" asp-route-id="@set.Id" class="btn btn-outline-success">Export PBN</a>
                            <form asp-action="Delete" asp-route-id="@set.Id" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this board set and all its boards?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-danger">Delete</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info mt-3">
            No board sets have been created yet. <a asp-action="Create">Create your first set!</a>
        </div>
    }
</div>
