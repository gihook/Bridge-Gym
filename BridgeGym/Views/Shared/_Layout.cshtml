@using Microsoft.AspNetCore.Localization
@using Microsoft.Extensions.Options
@inject IOptions<RequestLocalizationOptions> LocOptions
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BridgeGym</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/BridgeGym.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">BridgeGym</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Exercise" asp-action="Index">@Localizer["Exercise"]</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="History" asp-action="Index">@Localizer["History"]</a>
                        </li>
                    </ul>
                    <partial name="_LoginPartial" />
                    <form id="selectLanguage" asp-controller="Language" asp-action="SetLanguage" asp-route-returnUrl="@Context.Request.Path" method="post" class="d-flex align-items-center ms-3">
                        @{
                            var requestCulture = Context.Features.Get<IRequestCultureFeature>();
                            var cultures = LocOptions.Value.SupportedUICultures?.ToList() ?? new List<System.Globalization.CultureInfo>();
                            
                            // Safe fallback names in case Linux ICU doesn't know the NativeName
                            var cultureNames = new Dictionary<string, string>
                            {
                                { "en", "English" },
                                { "es", "Español" },
                                { "sr", "Srpski" },
                                { "fr", "Français" },
                                { "de", "Deutsch" }
                            };
                        }
                        <select name="culture" onchange="this.form.submit();" class="form-select form-select-sm">
                            @foreach (var culture in cultures)
                            {
                                var displayName = cultureNames.ContainsKey(culture.Name) ? cultureNames[culture.Name] : culture.NativeName;
                                <option value="@culture.Name" selected="@(culture.Name == requestCulture?.RequestCulture.UICulture.Name)">@displayName</option>
                            }
                        </select>
                    </form>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - BridgeGym - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
